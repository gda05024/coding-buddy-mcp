#!/bin/bash
# Coding Buddy — 프롬프트 분석 후 적합한 모델로 Claude Code 세션 시작
# Haiku로 복잡도를 판단한 뒤 적합한 모델로 대화형 세션을 연다.
# 비용: Haiku 1회 호출 ~$0.001 이하

PROMPT="$*"

# 인자 없으면 기본 sonnet
if [ -z "$PROMPT" ]; then
  echo "🤖 모델: sonnet (기본값)"
  claude --model sonnet
  exit 0
fi

# Haiku에게 복잡도 판단 위임
COMPLEXITY=$(claude --model haiku -p "다음 작업의 복잡도를 simple, medium, complex 중 하나의 단어로만 답하라. 다른 말 하지 마라.

simple: 오타 수정, 이름 변경, 포맷팅, 간단한 조회, 주석 추가, import 추가
medium: 기능 구현, 버그 수정, 테스트 작성, 코드 리뷰, 단일 파일 변경
complex: 아키텍처 변경, 마이그레이션, 전체 리팩토링, 시스템 설계, 다중 파일 대규모 변경

작업: ${PROMPT}" 2>/dev/null | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')

# 복잡도 → 모델 매핑
case "$COMPLEXITY" in
  simple)
    MODEL="haiku"
    PRICE="\$1/\$5"
    ;;
  complex)
    MODEL="opus"
    PRICE="\$15/\$75"
    ;;
  *)
    MODEL="sonnet"
    PRICE="\$15/\$75"
    ;;
esac

echo "🤖 프롬프트 분석 완료"
echo "   복잡도: ${COMPLEXITY}"
echo "   모델: ${MODEL} (${PRICE} per 1M tokens)"
echo ""

claude --model "$MODEL"
